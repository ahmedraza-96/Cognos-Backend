# Copy to .env.production ON THE SERVER and fill in. Never commit the real file.
# Host names point at the docker-compose service "postgres" (not localhost),
# and data dirs point at the /app/data volume mount.

# --- App ---
APP_NAME="AI Agent Platform"
ENVIRONMENT=production
# Set to your Vercel frontend URL once it exists (see deploy step D).
# Comma-separated if you need to allow more than one origin.
CORS_ORIGINS=https://<your-app>.vercel.app

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database (Postgres container; host = compose service name "postgres") ---
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/agentdb
CHECKPOINT_DB_URL=postgresql://agent:agent@postgres:5432/agentdb

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Tavily web search (optional) ---
TAVILY_API_KEY=

# --- RAG / Chroma + uploads (inside the app-data volume) ---
CHROMA_DIR=/app/data/chroma
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_MB=10

# --- HTTP tool SSRF allowlist ---
HTTP_TOOL_ALLOWED_HOSTS=api.github.com,httpbin.org
