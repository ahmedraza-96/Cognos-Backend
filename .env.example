# Copy to .env and fill in. Never commit the real .env.

# --- App ---
APP_NAME="AI Agent Platform"
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
# Generate a strong secret, e.g. python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database (Postgres via docker-compose) ---
# Async URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agentdb
# Sync URL used by the LangGraph Postgres checkpointer (psycopg)
CHECKPOINT_DB_URL=postgresql://agent:agent@localhost:5432/agentdb

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Tavily web search (optional; web-search tool disabled if absent) ---
TAVILY_API_KEY=

# --- RAG / Chroma ---
CHROMA_DIR=./data/chroma

# --- Uploads ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=10

# --- HTTP tool SSRF allowlist (comma-separated host suffixes) ---
HTTP_TOOL_ALLOWED_HOSTS=api.github.com,httpbin.org
